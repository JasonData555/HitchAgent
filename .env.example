# Airtable
AIRTABLE_API_KEY=pat_xxxxxxxxxxxx        # Personal access token (data.records:read/write, schema.bases:read)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX      # Base ID from the Airtable URL
AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXXX    # Candidate Tile table ID (from Airtable API docs or URL)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx   # API key from console.anthropic.com

# Vercel Blob (auto-injected when a Blob store is linked to this project)
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxx

# Internal authentication — must match x-api-key header sent by Airtable buttons
INTERNAL_API_KEY=your-secret-key-here

# Assets
HITCH_LOGO_URL=https://...              # Publicly accessible Hitch Partners logo URL (PNG or JPG)
